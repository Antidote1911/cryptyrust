pkgname=cryptyrust-appimage
pkgver=1.3.4
pkgrel=1
pkgdesc="Simple cross-platform file encryption with a drag-and-drop GUI and a CLI (AppImage)"
arch=('x86_64')
url="https://github.com/Antidote1911/cryptyrust"
license=('GPL-3.0-only')
depends=('fuse2')
provides=('cryptyrust')
conflicts=('cryptyrust' 'cryptyrust-git')
options=('!strip')
source=("cryptyrust-${pkgver}.AppImage::https://github.com/Antidote1911/cryptyrust/releases/download/v${pkgver}/cryptyrust-${pkgver}-linux.AppImage")
sha256sums=('SKIP')

prepare() {
    chmod +x "${srcdir}/cryptyrust-${pkgver}.AppImage"
    cd "$srcdir"
    "./cryptyrust-${pkgver}.AppImage" --appimage-extract
}

package() {
    # CLI binaire extrait de l'AppImage
    install -Dm755 "$srcdir/squashfs-root/usr/bin/cryptyrust_cli" \
        "$pkgdir/usr/bin/cryptyrust_cli"

    # AppImage installée dans /usr/lib
    install -Dm755 "$srcdir/cryptyrust-${pkgver}.AppImage" \
        "$pkgdir/usr/lib/cryptyrust/cryptyrust.AppImage"

    # Wrapper pour la GUI dans le PATH
    install -dm755 "$pkgdir/usr/bin"
    printf '#!/bin/sh\nexec /usr/lib/cryptyrust/cryptyrust.AppImage "$@"\n' \
        > "$pkgdir/usr/bin/cryptyrust"
    chmod 755 "$pkgdir/usr/bin/cryptyrust"

    # Fichier .desktop (à la racine du squashfs dans un AppImage linuxdeploy)
    install -Dm644 "$srcdir/squashfs-root/cryptyrust.desktop" \
        "$pkgdir/usr/share/applications/cryptyrust.desktop"

    # Icône
    install -Dm644 "$srcdir/squashfs-root/cryptyrust.png" \
        "$pkgdir/usr/share/icons/hicolor/512x512/apps/cryptyrust.png"
}
